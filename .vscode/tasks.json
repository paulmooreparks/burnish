{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build burnish (install to ~/bin)",
      "type": "process",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy", "Bypass",
        "-File", "${workspaceFolder}/scripts/build.ps1"
      ],
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": ["$go"],
      "presentation": { "reveal": "always", "panel": "shared", "clear": true },
      "detail": "go build ./cmd/burnish -> %USERPROFILE%\\bin\\burnish.exe"
    }
  ]
}
